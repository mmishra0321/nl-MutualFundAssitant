# Copy to `.env` in the repo root:  cp .env.example .env
# Never commit `.env`.

# --- Local development (./scripts/run_local.sh) ---
# STREAMLIT_SERVER_PORT=8501
# MS02_API_HOST=127.0.0.1
# MS02_API_PORT=8000
# MS02_SKIP_API=0          # set to 1 to run Streamlit only (no REST API)

# Phase 3 — Groq chat API (optional; extractive fallback if unset)
GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant

# Set to 0 to disable Groq even when GROQ_API_KEY is set
# MS02_USE_GROQ=1
